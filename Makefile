###############################################################################
# Proyecto
###############################################################################

TARGET = seed

###############################################################################
# Compilador
###############################################################################

CC = gcc

###############################################################################
# Carpetas
###############################################################################

SRC_DIR = src
INC_DIR = include
BUILD_DIR = build

###############################################################################
# Flags
###############################################################################

CFLAGS = -Wall \
          -Wextra \
          -std=c17 \
          -I$(INC_DIR)

###############################################################################
# Buscar automáticamente todos los .c
###############################################################################

SOURCES := $(shell find $(SRC_DIR) -name "*.c")

###############################################################################
# Generar nombres de objetos
###############################################################################

OBJECTS := $(patsubst $(SRC_DIR)/%.c,$(BUILD_DIR)/%.o,$(SOURCES))

###############################################################################
# Regla principal
###############################################################################

all: $(BUILD_DIR)/$(TARGET)

###############################################################################
# Ejecutable
###############################################################################

$(BUILD_DIR)/$(TARGET): $(OBJECTS)
	@mkdir -p $(BUILD_DIR)
	$(CC) $(OBJECTS) -o $@

###############################################################################
# Compilar cada .c
###############################################################################

$(BUILD_DIR)/%.o: $(SRC_DIR)/%.c
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -c $< -o $@

###############################################################################
# Ejecutar
###############################################################################

run: all
	./$(BUILD_DIR)/$(TARGET)

###############################################################################
# Limpiar
###############################################################################

clean:
	rm -rf $(BUILD_DIR)

###############################################################################
# Recompilar
###############################################################################

re: clean all

###############################################################################
# Ayuda
###############################################################################

help:
	@echo ""
	@echo "make        -> Compilar"
	@echo "make run    -> Compilar y ejecutar"
	@echo "make clean  -> Limpiar"
	@echo "make re     -> Recompilar"